{
  "name": "oide",
  "version": "0.0.0",
  "description": "GitHub Action that pulls files listed in your Oidefile from a source repository.",
  "license": "MIT",
  "author": "Takashi Iwamoto",
  "homepage": "https://github.com/iwamot/oide",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iwamot/oide.git"
  },
  "bugs": {
    "url": "https://github.com/iwamot/oide/issues"
  },
  "keywords": [
    "github-action",
    "governance",
    "template"
  ],
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "bun build src/main.ts --outfile dist/index.js --target node",
    "check": "biome check",
    "check:write": "biome check --write",
    "prune": "pnpm-override-prune --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "24.13.2",
    "typescript": "6.0.3"
  }
}
